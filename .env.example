# Copy to .env and adjust as needed. docker-compose.yml reads this file automatically.
# No real secrets belong here — Postgres/Redis credentials below are local-dev-only
# placeholders for a database that only ever runs on your own machine / CI, never exposed.

# --- Postgres ---
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=orchestrator
POSTGRES_DB=orchestrator
# Used by the server; docker-compose overrides the host to the `postgres` service name.
DATABASE_URL=postgres://orchestrator:orchestrator@localhost:5432/orchestrator?sslmode=disable

# --- Redis ---
REDIS_ADDR=localhost:6379

# --- Server ---
HTTP_ADDR=:8080
GRPC_ADDR=:9090
NODE_ID=server-1
# Set to "true" to enable Phase 2 sharded scheduling (consistent hashing + Redis leader
# election). Safe to leave false for a single server instance — see README's "Phase 2
# features and their tradeoffs" section.
ENABLE_SHARDING=false
# How long a worker holds a claimed task before the reaper considers it abandoned.
LEASE_DURATION_SECONDS=30

# --- Worker ---
WORKER_ID=worker-1
SERVER_GRPC_ADDR=localhost:9090
WORKER_CONCURRENCY=4

# --- Auth ---
# Shared secret required as `Authorization: Bearer <key>` on every HTTP API route except
# /healthz, and as gRPC metadata on every worker-API call. Read by the server, the worker,
# and (via docker-compose's frontend build args) baked into the dashboard build.
#
# THIS DEFAULT IS PUBLIC (it's in this file, in the repo). It's fine for local/dev use only —
# set this to a real generated secret before running the stack anywhere reachable by anyone
# but you, e.g.: `openssl rand -hex 32`.
WORKFLOW_API_KEY=dev-local-key-change-me
# CORS allowlist for the HTTP API (comma-separated). Access-Control-Allow-Origin only ever
# reflects an exact match from this list — never a wildcard. Default matches the `frontend`
# service's docker-compose host port.
CORS_ALLOWED_ORIGINS=http://localhost:3002

# --- Frontend (build-time) ---
# The dashboard talks to /api on whatever origin it's served from; nginx (see
# frontend/nginx.conf) reverse-proxies that to the server container in docker-compose, so no
# frontend-specific API URL env var is needed. It does need the API key baked in at build
# time (docker-compose passes WORKFLOW_API_KEY above as the `VITE_API_KEY` build arg) so the
# browser can authenticate — see frontend/Dockerfile and frontend/src/api.ts.
